- partial_path = 'communities/electric_rates_sales/yearly_customers'

-# --- Section Body ---
.section-body.m-1.m-md-2.m-lg-4.mt-3
  .row
    .col-12
      .p-4.border.rounded-3.bg-white.shadow-sm.mb-4
        - if @community.yearly_sales.with_customers.exists?
          .mb-5
            = render "#{partial_path}/customers_chart"

        -# Data Table Section
        .pt-4.border-top
          .d-flex.align-items-center.mb-3
            %i.bi.bi-table.me-2.text-primary
            %h5.mb-0.fw-bold Electricity Customer Data
          = render "#{partial_path}/customers_data"
