.d-flex.flex-column.position-sticky{ style: "top: 60px; height: calc(100vh - 60px);" }
  .flex-grow-1.d-flex.flex-column#mapbox-area
    .d-flex.align-items-center
      / --- Floating controls ---
      .position-absolute.top-0.end-0.bg-white.border.rounded-3.shadow-sm.m-2.p-3{ style: "z-index:5;" }
        .fw-semibold.small.mb-2.text-center.border-bottom.pb-1 Select a Map Layer
        - if @community.local_service_area?
          .form-check.d-flex.align-items-center.mb-1
            %input.form-check-input#service-area-geom{ 
              type: "checkbox", 
              data: { 
                action: "change->maps#toggleLayer",
                url: service_area_geom_community_maps_path(@community), 
                fit: true
              }
            }
            %label.form-check-label.small.ms-2{ for: "service-area-geom" }
              %span.legend-swatch{ data: { maps_target: "swatch" } }
              Local Service Area

          / Map Layer: Utility Service Area (if applicable)
        - if @community.service_areas?
          .form-check.d-flex.align-items-center.mb-1
            %input.form-check-input#service-area{
              type: "checkbox",
              data: {
                action: "change->maps#toggleLayer",
                url: service_area_community_maps_path(@community),
                fit: true
              }
            }
            %label.form-check-label.small.ms-2{ for: "service-area" }
              %span.legend-swatch{ data: { maps_target: "swatch" } }
              Utility Service Area
        
        - if @community.house_districts?  
          .form-check.d-flex.align-items-center.mb-1
            %input.form-check-input#house-districts{ 
              type: "checkbox", 
              data: { 
                action: "change->maps#toggleLayer", 
                url: house_districts_community_maps_path(@community), 
                fit: true 
              } 
            }
            %label.form-check-label.small.ms-2{ for: "house-districts" }
              %span.legend-swatch{ data: { maps_target: "swatch" } }
              House Districts

        - if @community.senate_districts?
          .form-check.d-flex.align-items-center.mb-1
            %input.form-check-input#senate-districts{ 
              type: "checkbox", 
              data: { 
                action: "change->maps#toggleLayer", 
                url: senate_districts_community_maps_path(@community), 
                fit: true 
              } 
            }
            %label.form-check-label.small.ms-2{ for: "senate-districts" }
              %span.legend-swatch{ data: { maps_target: "swatch" } }
              Senate Districts

        - if @community.plants?
          .form-check.d-flex.align-items-center.mb-1
            %input.form-check-input#plants-points{ 
              type: "checkbox", 
              data: { 
                action: "change->maps#toggleLayer", 
                url: plants_community_maps_path(@community), 
                fit: true 
              } 
            }
            %label.form-check-label.small.ms-2{ for: "plants-points" }
              %span.legend-swatch{ data: { maps_target: "swatch" } }
              Power Plants

        - if @community.bulk_fuel_facilities?
          .form-check.d-flex.align-items-center.mb-1
            %input.form-check-input#bulk-fuel-facilities-points{ 
              type: "checkbox", 
              data: { 
                action: "change->maps#toggleLayer", 
                url: bulk_fuel_facilities_community_maps_path(@community), 
                fit: true 
              } 
            }
            %label.form-check-label.small.ms-2{ for: "bulk-fuel-facilities-points" }
              %span.legend-swatch{ data: { maps_target: "swatch" } }
              Bulk Fuel Facilities

    .flex-grow-1.position-relative
      .h-100{ data: { maps_target: "map" } }
