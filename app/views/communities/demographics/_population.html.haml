- parent_tab = 'demographics'

-# --- Section Body ---
.section-body.m-1.m-md-2.m-lg-4.mt-3
  .mb-4
    = render "communities/#{parent_tab}/population/estimated_population"
  
  -# Main Data Card
  .p-4.border.rounded-3.bg-white.shadow-sm.mb-4
    .row.g-4
      - if @community.age_distribution?
        .col.col-xl-8
          .d-flex.align-items-center.mb-3
            %i.bi.bi-bar-chart-steps.me-2.text-primary
            %h5.mb-0.fw-bold Age Distribution
          %p.small.text-muted.mb-3
            = "Estimated population counts by age cohort - based on American Community Survey (ACS) "
            %span.dotted-underline{ data: { controller: 'tooltip', bs_toggle: 'tooltip' }, title: "ACS 5-year estimates are collected over a 60-month period. This reflects the average characteristics of the population over the entire timeframe rather than a single point in time." } 5-year estimates
            = " for the selected period."
        
          = render "communities/#{parent_tab}/population/population_age_chart"
          
      - if @community.sex_distribution?
        .col.col-xl-4
          .d-flex.align-items-center.mb-3
            %i.bi.bi-gender-ambiguous.me-2.text-primary
            %h5.mb-0.fw-bold Sex Distribution
          %p.small.text-muted.mb-3
            = "Estimated population counts by sex - based on American Community Survey (ACS) "
            %span.dotted-underline{ data: { controller: 'tooltip', bs_toggle: 'tooltip' }, title: "ACS 5-year estimates are collected over a 60-month period. This reflects the average characteristics of the population over the entire timeframe rather than a single point in time." } 5-year estimates
            = " across all available periods."
        
          = render "communities/#{parent_tab}/population/population_sex_chart"

    -# Data Table Section
    .pt-4.border-top.mt-5
      .d-flex.align-items-center.mb-3
        %i.bi.bi-table.me-2.text-primary
        %h5.mb-0.fw-bold Population Data
      = render "communities/#{parent_tab}/population/population_age_sex_datatable"