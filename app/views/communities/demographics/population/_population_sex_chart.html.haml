- chart_id           = "sex-distribution-chart"

.sex-chart-wrapper{ data: {
                      controller: "sex-distribution-chart",
                      sex_distribution_chart: {
                        title_value: "Sex Distribution",
                        url_value: sex_distribution_community_charts_path(@community),
                        male_bar_color_value: color(:blue),
                        female_bar_color_value: color(:orange)
                      }
                    }
                  }

  .d-flex.align-items-center.gap-2.mb-3
    %i.bi.bi-info-circle-fill.text-aedg-navy{
      data: { controller: 'tooltip', bs_toggle: 'tooltip' },
      title: "American Community Survey (ACS) 5-year estimates is data collected over a 60-month period. The data reflects the average characteristics of the population between the start and end dates."
    }
    %label.form-label.me-2.mb-0.fw-bold ACS 5-year period

  .chart-container.mt-4{ style: "min-height: 500px;" }
    %canvas{ id: chart_id, data: { "sex-distribution-chart-target": "canvas" } }
