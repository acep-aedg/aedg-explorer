-# locals: (id:, title:)
-# Modal structure
.modal.fade{ id: id, tabindex: "-1", aria: { labelledby: "#{id}Label" } }
  .modal-dialog.modal-dialog-centered
    .modal-content
      .modal-header
        %h5.modal-title{ id: "#{id}Label" }= title
        %button.btn-close{ type: "button", data: { bs_dismiss: "modal" }, aria: { label: "Close" } }
      .modal-body
        = yield
          
      .modal-footer
        %button.btn.btn-secondary{ type: "button", data: { bs_dismiss: "modal" } } Close