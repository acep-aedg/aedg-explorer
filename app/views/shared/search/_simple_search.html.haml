/ --- SEARCH BAR ---
%div.text-center
  = form_with url: polymorphic_path(model), method: :get do |f|
    .input-group.bg-white.mx-auto.search-bar.ps-4
      = f.search_field :q, value: @query, class: "form-control border-0", placeholder: search_placeholder_for(model)
      - if @query.present?
        = link_to polymorphic_path(model), class: 'btn btn-white border-0' do
          %i.bi.bi-x.text-secondary
      = f.button name: nil, class: 'btn btn-white border-0' do
        %i.bi.bi-search.text-muted
