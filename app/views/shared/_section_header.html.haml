-# locals: (icon:, title:, description:, anchor: nil, about_modal_id:nil, related_metadata:[])
- metadata_records = Array(related_metadata).map { |k| get_related_metadata(k) }.compact

.section-title-bar.bg-body-secondary.border-start.border-primary.border-5.p-3.mb-1.mb-md-3.mb-lg-4
  .d-flex.align-items-center
    -# Icon Container
    .bg-primary-subtle.rounded-circle.p-2.p-md-3.me-3.d-inline-flex.align-items-center.justify-content-center
      %i.fs-3.text-primary.lh-1{ class: "bi bi-#{icon}" }

    -# Text Content
    %div
      %h3.h5.mb-0.text-uppercase.fw-bold.d-flex.align-items-center
        = title

        -# Share Button
        - if anchor.present?
          %button.btn.btn-link.p-0.ms-2{ aria: { label: "Copy link to #{title}" }, data: { controller: "copy",
            action: "copy#copy",
            copy_url_value: "#{request.base_url}#{request.path}#{anchor}",
            copy_target: "button",
            copy_icon_original: "bi-link-45deg",
            copy_icon_success: "bi-check-lg",
            copy_active_class: "text-success",
            copy_original_class: "text-muted" } }

            %i.bi.bi-link-45deg.fs-4{ data: { copy_target: "icon" }, aria: { hidden: "true" } }
      -# Description
      - if description.present?
        %small.text-muted= description

    -# Buttons Container
    .ms-auto.d-flex.flex-column.align-items-end.gap-2
      -# About Modal Button
      - if about_modal_id.present?
        %button.btn.btn-sm.btn-aedg-secondary.w-100.text-nowrap{ type: "button", data: { bs_toggle: "modal", bs_target: "##{about_modal_id}" } }
          %i.bi.bi-info-circle.me-1{ aria: { hidden: "true" } }
          About this Data

      -# View Datasets Button
      - if metadata_records.any?
        - if metadata_records.one?
          = link_to metadatum_path(metadata_records.first), data: { turbo_frame: "_top" }, class: "btn btn-sm btn-aedg-primary w-100 text-nowrap" do
            %i.bi.bi-database.me-1{ aria: { hidden: "true" } }
            View Dataset
        - else
          .dropdown.w-100.text-nowrap
            %button.btn.btn-sm.btn-aedg-primary.dropdown-toggle{ data: { bs_toggle: "dropdown" }, type: "button", aria: { expanded: "false", haspopup: "true" }}
              %i.bi.bi-database.me-1{ aria: { hidden: "true" } }
              View Datasets
            %ul.dropdown-menu.dropdown-menu-end{ aria: { labelledby: "dropdown-#{title.parameterize}" } }
              - metadata_records.each do |m|
                %li
                  = link_to metadatum_path(m), data: { turbo_frame: "_top" }, class: "dropdown-item small" do
                    %i.bi.bi-file-earmark.me-2{ aria: { hidden: "true" } }
                    = m.title
