.section-body.m-1.m-md-2.m-lg-4.mt-3
  .d-flex.align-items-start.mb-3.border-bottom.pb-2
    %h5.mb-3
      The
      %strong= @grid.name
      = " serves #{pluralize(@grid.communities.count, 'community')}:"
      
  .row.g-3
    - @grid.communities.each do |c|
      .col-6.col-sm-4.col-lg-2
        = link_to c.name, community_path(c),
          class: "btn btn-light border w-100 h-100 shadow-sm d-flex align-items-center justify-content-center text-wrap",
          data: { turbo_frame: '_top' }
