- content_for :title, page_title(@communities, @community)
- content_for :content do
  -# Main Toolbar
  = render "shared/toolbar",
    entity: @community,
    collection: @communities,
    tabs: community_navigation_tabs(@community),
    target_frame: "community_tab_content"

  -# Wrap Entire Page with Mapbox API data
  .row.gx-0{ data: mapbox_api_data({
      maps_map_center_value: [@community.longitude, @community.latitude],
      maps_markers_value: [[@community.longitude, @community.latitude]],
      maps_marker_tooltip_title_value: @community.name
      })
    }
    -# Sidebar with Map
    .col-md-4.d-none.d-lg-block
      = render 'communities/map_sidebar'

    -# Main Content Area
    .col-md-12.col-lg-8
      = turbo_frame_tag "community_tab_content", data: { controller: "scroll", 
                                  action: "turbo:frame-render->scroll#scrollToTop" } do
        = yield

= render template: "layouts/application"