- content_for :title, "Electric Grid - #{@community&.name}"
- content_for :content do
  -# Sticky Toolbar
  = render 'grids/sticky_toolbar'

  .row.gx-0{ data: mapbox_api_data({maps_default_layer_id_value: "layer-communities"})
  }
    -# Sidebar with Map
    .col-md-4.d-none.d-lg-block
      = render 'grids/map_sidebar'

    -# Main Content Area
    .col-md-12.col-lg-8
      = turbo_frame_tag "grid_tab_content", data: { controller: "scroll", 
                                  action: "turbo:frame-render->scroll#scrollToTop" } do
        = yield

= render template: "layouts/application"