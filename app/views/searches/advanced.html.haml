.container-fluid
  / Back Button
  .row.mb-3
    .col-12
      = link_to communities_path, class: 'text-decoration-none ms-1 icon-link icon-link-hover d-inline-flex align-items-baseline' do
        %i.bi.bi-arrow-left.me-1
        Back

  -# ONE controller at the top level to coordinate sidebar, panels, and form
  .row.flex-nowrap.position-relative{ data: { controller: "search-panels" }, style: "overflow: visible !important;" }
    
    -# COLUMN 1: Sidebar (Updated via Turbo Stream)
    .col-md-4.main_nav_sidebar#sidebar_column
      #sidebar_nav_area
        %h2.fw-bold.mb-1 Community Explorer
        %p.text-muted Filter communities by specific criteria.
        - if @active_badges&.any?
          #active_filters_list
            = render 'searches/advanced/active_filters'
        #sidebar_nav   
          = render 'searches/advanced/sidebar_nav'

    -# COLUMN 2: THE STAGE (Panels + Hidden Form)
    .panel-stage
      #search_panels_content
        .search-container
          = render 'searches/advanced/panels'
          -# Putting the form here ensures the controller can find the 'tracker' target
          = render 'searches/advanced/form' 

    -# COLUMN 3: Results (Updated via Turbo Stream)
    .col-md-8.main_results_area#main_content_column
      .results-view.mt-4
        #results_frame
          = render 'searches/advanced/results'