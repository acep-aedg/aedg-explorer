- id_prefix = panel[:prefix]
- frame_id  = "#{id_prefix}_frame"
- param_key = panel[:param]

= turbo_frame_tag frame_id, class: "d-flex flex-column h-100", data: { turbo_action: "advance" }  do
  .d-flex.ps-4.flex-grow-1.overflow-hidden
    .flex-grow-1.overflow-auto
      - if panel[:items].any?
        - selected_ids = Array(@state_params[param_key.to_s] || @state_params[param_key.to_sym]).map(&:to_s)
        
        - panel[:items].each do |item|
          - val = item.send(panel[:lookup]).to_s
          - lbl = panel[:label_method].is_a?(Proc) ? panel[:label_method].call(item) : (item.respond_to?(panel[:label_method]) ? item.send(panel[:label_method]) : "District #{item.try(:district)}")

          .form-check.mb-1
            = check_box_tag "#{param_key}[]", 
                val, 
                selected_ids.include?(val),
                id: "#{id_prefix}_#{val}",
                class: 'form-check-input',
                form: 'filter-form',
                data: { action: "change->search-panels#autoSubmit" }
            = label_tag "#{id_prefix}_#{val}", lbl, class: 'form-check-label small'

        - if panel[:pagy] && panel[:pagy].pages > 1
          .py-2.d-flex.justify-content-center.small-pagy
            -# Pagy 43: Calling the series_nav member method
            != panel[:pagy].series_nav(:bootstrap, link_extra: "data-turbo-frame='#{frame_id}' data-turbo-action='advance'")

      - else
        .text-center.py-4.small.text-muted No results found.

    -# ALPHABET NAV
    .facet-alphabet-nav.d-flex.flex-column.align-items-center.bg-light.border-start.ms-2{ style: "min-width: 30px;" }
      = button_tag type: 'button', 
                  class: "alphabet-link btn btn-link",
                  data: { action: "click->search-panels#setAlpha", 
                          search_panels_letter_param: "", 
                          search_panels_prefix_param: id_prefix } do
        %i.bi.bi-list

      - ('A'..'Z').each do |letter|
        - available = panel[:available_letters] || []
        - is_active = @state_params["alpha_#{id_prefix}"] == letter

        - if available.include?(letter)
          = button_tag letter,
              type: 'button',
              class: "alphabet-link #{is_active ? 'active' : ''}",
              data: { action: "click->search-panels#setAlpha", 
                      search_panels_letter_param: letter,
                      search_panels_prefix_param: id_prefix }
        - else
          %span.alphabet-link.text-muted= letter