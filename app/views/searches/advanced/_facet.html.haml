- id_prefix = panel[:prefix]
- frame_id  = "#{id_prefix}_frame"
- param_key = panel[:param]

= turbo_frame_tag frame_id, class: "d-flex flex-column h-100" do
  -# 1. Ensure hidden alpha field is synced with @state_params
  = hidden_field_tag "alpha_#{id_prefix}", @state_params["alpha_#{id_prefix}"], id: "alpha_#{id_prefix}_input", form: 'filter-form'

  .d-flex.ps-4.flex-grow-1.overflow-hidden
    .flex-grow-1.overflow-auto
      - if panel[:items].any?
        -# 2. selected_ids should look at our comprehensive @state_params
        - selected_ids = Array(@state_params[param_key.to_s] || @state_params[param_key.to_sym]).map(&:to_s)
        
        - panel[:items].each do |item|
          - val = item.send(panel[:lookup]).to_s
          - lbl = panel[:label_method].is_a?(Proc) ? panel[:label_method].call(item) : (item.respond_to?(panel[:label_method]) ? item.send(panel[:label_method]) : "District #{item.try(:district)}")

          .form-check.mb-1
            = check_box_tag "#{param_key}[]", val, selected_ids.include?(val),
              id: "#{id_prefix}_#{val}",
              class: 'form-check-input',
              form: 'filter-form',
              data: { action: "change->search-panels#autoSubmit" }
            = label_tag "#{id_prefix}_#{val}", lbl, class: 'form-check-label small'

        - if panel[:pagy] && panel[:pagy].pages > 1
          .py-2.d-flex.justify-content-center.small-pagy
            -# Pagy helper now uses @state_params internally because we passed them in the controller
            != panel[:pagy].series_nav(:bootstrap, link_extra: "data-turbo-frame='#{frame_id}' data-turbo-action='advance'")

      - else
        .text-center.py-4.small.text-muted No results found.

    -# ALPHABET NAV
    .facet-alphabet-nav.d-flex.flex-column.align-items-center.bg-light.border-start.ms-2{ style: "min-width: 30px;" }
      -# 3. Clear link: Strip current facet alpha/query but keep other checkboxes from @state_params
      - clear_params = (@state_params || {}).merge("alpha_#{id_prefix}" => nil, "q_#{id_prefix}" => nil, only_facet: true)
      = link_to search_advanced_path(clear_params), 
                class: "alphabet-link btn btn-link p-0 mb-2", 
                data: { turbo_stream: true, turbo_action: "advance" } do
        %i.bi.bi-list

      - ('A'..'Z').each do |letter|
        - available = panel[:available_letters] || []
        - is_active = @state_params["alpha_#{id_prefix}"] == letter

        - if available.include?(letter)
          -# 4. Merge letter into @state_params to ensure checkboxes persist in the link
          - link_params = (@state_params || {}).merge("alpha_#{id_prefix}" => letter, only_facet: true, expanded: panel[:id])
          
          = link_to letter, search_advanced_path(link_params),
            class: "alphabet-link #{is_active ? 'active' : ''}",
            data: { turbo_stream: true, turbo_action: "advance" }
        - else
          %span.alphabet-link.text-muted.small.p-0{ style: "opacity: 0.3;" }= letter