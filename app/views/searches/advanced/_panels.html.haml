%div#search_panels_content

  - if @facet_panels.present?
    - @facet_panels.each do |p|
      - is_open = (params[:expanded] == p[:id])
      .facet-panel{ id: p[:id], class: ('panel-visible' if is_open) }
        .facet-shelf-content.bg-white.shadow-sm.rounded
          .p-2.d-flex.justify-content-between.align-items-center.border-bottom
            %h5.mb-0.fw-bold{style: "font-size: 1rem;"}= p[:title]
            %button.btn-close{ type: "button", data: { action: "click->search-panels#close" } }
          
          .panel-body.p-2
            = render 'searches/advanced/facet', panel: p 