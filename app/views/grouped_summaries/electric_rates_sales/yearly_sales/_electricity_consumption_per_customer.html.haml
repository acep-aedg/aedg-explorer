.chart-wrapper{ style: "height: 500px; width: 100%;" }
  %canvas{
    data: {
      controller: "electricity-consumption-chart",
      electricity_consumption_chart: {
        url_value: polymorphic_path([:electricity_consumption_per_customer, @parent, :charts]),
        title_value: "#{@parent} - Electricity Consumption per Customer"
      }
    }
  }
