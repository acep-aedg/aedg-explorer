- partial_path = 'grouped_summaries/power_generation'

= turbo_frame_tag "tab_content" do  
  = render 'shared/tab_nav', links: @jump_to_links
  
  .scrollspy-container{ data: { controller: "scrollspy", bs_spy: "scroll", bs_target: "#jump-nav", bs_smooth_scroll: "true" }, tabindex: "0" }
    - if @parent.utilities?
      #utilities.scroll-section.mb-5
        = render 'shared/section_header', 
          icon: 'buildings', 
          title: 'Utilities', 
          description: 'Electrical providers, service areas, and grid infrastructure',
          anchor: '#utilities'
  
        = render "#{partial_path}/utilities"

    - if @parent.generation?
      #generation.scroll-section.mb-5
        = render 'shared/section_header',
          icon: 'building-gear',
          title: 'Generation',
          description: 'Energy generation trends and fuel source mix',
          anchor: '#generation',
          related_metadata: ["public_monthly_generation", "public_yearly_generation"],
          about_modal_id: 'generationAboutModal' # this id must match the id in the sections about_modal partial
        
        = render "#{partial_path}/generation/about_modal"
        = render "#{partial_path}/generation"
        
    - if @parent.capacities?
      #capacity.scroll-section.mb-5
        = render 'shared/section_header',
          icon: 'lightning-fill',
          title: 'Capacity',
          description: 'Installed infrastructure and maximum power output',
          anchor: '#capacity',
          related_metadata: ["public_capacity"],
          about_modal_id: 'capacityAboutModal' # this id must match the id in the sections about_modal partial
        
        = render "#{partial_path}/capacity/about_modal"
        = render "#{partial_path}/capacity"
