- content_for :title, page_title(@parents)

.container-xl.mt-4
  .row.justify-content-center.mb-5
    .col
      #grouped-summaries-hero.position-relative.text-center.rounded-4.p-0.p-md-3.p-lg-5
        .row.justify-content-center.mx-0
          .col-12.col-md-11.col-lg-10.bg-white.bg-opacity-75.p-4.rounded-4.shadow.position-relative
            %h1.fw-bold.m-3
              %i{ class: "bi #{summary_icon_for(@parents)} me-2" }
              = @parents.model_name.human.titleize.pluralize

            %p.lead.fs-5.mx-3
              = "Explore #{@parents.model_name.human.downcase} level insights, from communities served to energy metrics."
            .d-flex.flex-column.flex-sm-row.justify-content-center.align-items-center.gap-3.mb-4
              = link_to "View Data Explorer", search_metadata_path, class: "btn btn-lg btn-aedg-primary"
              = link_to "Advanced Community Search", search_advanced_path, class: "btn btn-lg btn-aedg-secondary"
            - if show_search_tools?(@parents)
              .row.justify-content-center
                .col.col-lg-10
                  = render 'shared/search/simple_search', model: @parents.model
      -# Photo Credit
      .text-end.text-small.text-muted.mt-2
        Photo Credit: Gwen Holdmann

-# Main Content / Results Section
.row.justify-content-center.g-5.mb-5.mx-0
  .col-xl-8.mt-0
    = turbo_frame_tag 'collection_list' do
      - if show_search_tools?(@parents) 
        = render 'shared/search/results_pagination', letters: @active_letters, model: @parents.model
      = render 'shared/search/results_list', collection: @parents