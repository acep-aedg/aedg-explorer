- service_area_label = "service area"
.p-4.border.rounded-3.bg-white.h-100.shadow-sm
  .d-flex.align-items-center.mb-3.border-bottom.pb-2
    %i.bi.bi-info-circle.me-2.text-primary
    %h5.mb-0.fw-bold Service Area Details
  
  / --- Utility Providers ---
  - if @parent.service_areas?
    .mb-4
      .d-flex.align-items-center.mb-1
        %label.text-muted.small.text-uppercase.fw-bold.mb-0 Utility Providers (#{@parent.service_areas.distinct.size})
        %i.bi.bi-info-circle-fill.ms-2.text-navy.small{ data: { controller: 'tooltip', bs_toggle: 'tooltip' }, title: "Certified entities providing utility services within this region" }
      %ul.list-unstyled.mt-1
        - @parent.service_areas.distinct.each do |sa|
          %li.d-flex.align-items-center.mb-2
            %i.bi.bi-dot.text-primary.fs-5.lh-1
            %span.fw-semibold= sa.name
            - if sa.certificate_url.present?
              = link_to sa.certificate_url, target: "_blank", rel: "noopener", class: "btn btn-sm btn-outline-primary py-0 px-2 ms-2", style: "font-size: 0.75rem;" do
                %i.bi.bi-box-arrow-up-right
                Cert

  / --- Power Plants ---
  - if @parent.plants?
    .mb-4
      .d-flex.align-items-center.mb-1
        %label.text-muted.small.text-uppercase.fw-bold.mb-0 Energy Assets (#{@parent.plants.size})
        %i.bi.bi-info-circle-fill.ms-2.text-navy.small{ data: { controller: 'tooltip', bs_toggle: 'tooltip' }, title: "Energy assests within this region" }
      
      .row.g-2.mt-1
        - @parent.plants.in_groups(2, false).each do |plant_group|
          .col-6
            %ul.list-unstyled.mb-0
              - plant_group.each do |plant|
                %li.text-wrap.mb-1.d-flex.align-items-center
                  %i.bi.bi-dot.text-primary.fs-5.lh-1
                  %span= plant.name