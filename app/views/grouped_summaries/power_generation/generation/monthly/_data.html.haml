- cache cache_key = [@parent, @parent.monthly_generations.maximum(:updated_at), "grid_monthly_gen_table_v1"] do
  - show_pce_price = @parent.pce_eligible_communities?

  %div{ data: { controller: 'datatables', datatables: { order_value: [3, 'asc']} } }
    %table.table.table-sm.table-stripped.border{ data: { datatables_target: 'table'} }
      %thead
        %tr
          %th Plant
          %th Year
          %th Month
          %th Generation (MWh)
          %th Fuel Type Name (Code)
          - if show_pce_price
            %th PCE Fuel Price ($/MWh)
          %th Quantity Consumed for Electricity (MMBtu)
          %th Quantity Consumed for Electric Generation (Physical Unit)
          %th Source
      %tbody
        - @parent.monthly_generations.includes(:plant).each do |generation|
          %tr
            %td= generation.plant.name
            %td= generation.year
            %td= generation.month
            %td= generation.generation_mwh
            %td= "#{generation.fuel_type_name} (#{generation.fuel_type_code})"
            - if show_pce_price
              %td= generation.pce_fuel_price
            %td= generation.quantity_consumed_for_electricity_mmbtu
            %td= "#{generation.quantity_consumed_in_physical_units_for_electric_generation} #{generation.physical_unit_label}"
            %td= generation.source